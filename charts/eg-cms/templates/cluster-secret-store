{{- if and .Values.externalSecrets.enabled .Values.externalSecrets.createSecretStore }}
apiVersion: external-secrets.io/v1
kind: ClusterSecretStore
metadata:
  name: {{ .Values.externalSecrets.secretStoreRef.name }}
  labels:
    {{- include "eg-cms.labels" . | nindent 4 }}
spec:
  provider:
    gcpsm:
      projectID: {{ .Values.global.project }}
      secretVersionSelectionPolicy: LatestOrFail
      auth:
        workloadIdentity:
          clusterLocation: {{ .Values.global.region }}
          clusterName: {{ .Values.global.cluster }}
          serviceAccountRef:
            name: {{ .Values.externalSecrets.secretStoreRef.serviceAccountName }}
            namespace: {{ .Values.externalSecrets.secretStoreRef.serviceAccountNamespace }}
{{- end }}